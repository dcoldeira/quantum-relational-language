# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# LLM provider: claude | together | ollama (default: claude)
LLM_PROVIDER=claude

# Bell platform API key — protects /ask and /jobs endpoints.
# Leave unset to disable auth (dev mode). Set a strong random value in production.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# BELL_API_KEY=

# Anthropic Claude API key (required when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Together.ai API key (required when LLM_PROVIDER=together)
# TOGETHER_API_KEY=...

# Ollama settings (optional, when LLM_PROVIDER=ollama)
# OLLAMA_MODEL=deepseek-coder-v2:16b
# OLLAMA_HOST=http://localhost:11434
