# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# LLM provider: claude | together | ollama (default: claude)
LLM_PROVIDER=claude

# Anthropic Claude API key (required when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Together.ai API key (required when LLM_PROVIDER=together)
# TOGETHER_API_KEY=...

# Ollama settings (optional, when LLM_PROVIDER=ollama)
# OLLAMA_MODEL=deepseek-coder-v2:16b
# OLLAMA_HOST=http://localhost:11434
